# Copy to .env.local and fill in. Validated at boot by src/env.ts (@t3-oss/env-nextjs + Zod).
# Never commit .env.local. Empty strings are coerced to undefined; required vars must be set.
# Escape hatch: SKIP_ENV_VALIDATION=1 bypasses Zod validation (e.g. for next build in Docker).

# --- Database ---
DATABASE_URL="postgres://gamblino:gamblino@localhost:5432/gamblino"

# --- Auth ---
# openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# --- Email (magic-link provider) ---
# Use Mailhog locally, Resend in prod.
EMAIL_SERVER_HOST="localhost"
EMAIL_SERVER_PORT="1025"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@gamblino.local"

# --- Observability ---
SENTRY_DSN=""
# Client DSN (public, exposed to browser). Usually the same as SENTRY_DSN.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
LOG_LEVEL="debug"

# --- Feature flags (on|off) ---
FLAG_CRASH="on"
FLAG_MINES="on"
FLAG_PLINKO="on"

# --- Rate limits ---
# In-memory for dev. Upstash Redis for prod.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- WebSocket server ---
WS_PORT="3001"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Geo (MaxMind GeoLite2 on-prem DB) ---
MAXMIND_DB_PATH=

# --- Currency feature flags (T1 — only credit enabled in pre-license phase) ---
FLAG_CURRENCY_CREDIT=on
FLAG_CURRENCY_USD=off
FLAG_CURRENCY_USDT=off
FLAG_CURRENCY_USDC=off
FLAG_CURRENCY_BTC=off
FLAG_CURRENCY_ETH=off

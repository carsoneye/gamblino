{
  "permissions": {
    "allow": [
      "Bash(bun install)",
      "Bash(bun add *)",
      "Bash(bun run *)",
      "Bash(bun x *)",
      "Bash(bun test *)",
      "Bash(bunx shadcn *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git switch *)",
      "Bash(git checkout *)",
      "Bash(git pull *)",
      "Bash(git push *)",
      "Bash(fd *)",
      "Bash(docker compose up -d)",
      "Bash(docker compose down)",
      "Bash(bun x drizzle-kit *)",
      "Bash(gh pr *)",
      "Bash(gh run *)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(rm -rf *)",
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.production)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/phase-context.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd $CLAUDE_PROJECT_DIR && bun x biome check --write --no-errors-on-unmatched $CLAUDE_FILE_PATHS 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "enabledMcpServers": ["next-devtools"]
}
